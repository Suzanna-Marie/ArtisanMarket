generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CLIENT
  ARTISAN
  ADMIN
}

enum StatutArtisan {
  EN_ATTENTE
  VALIDE
  SUSPENDU
  REJETE
}

enum StatutProduit {
  BROUILLON
  PUBLIE
  RETIRE
  EN_RUPTURE
}

enum StatutCommande {
  RECUE
  EN_PREPARATION
  PRETE
  EN_LIVRAISON
  LIVREE
  ANNULEE
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  nom       String
  prenom    String
  telephone String?
  avatar    String?
  actif           Boolean   @default(true)
  emailVerifie    Boolean   @default(false)
  codeVerif       String?
  codeVerifExpire DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  artisan   Artisan?
  commandes Commande[] @relation("CommandeClient")
  avis      Avis[]
  favoris   Favori[]
  messages  Message[]
  adresses  Adresse[]

  @@map("users")
}

model Artisan {
  id             Int           @id @default(autoincrement())
  userId         Int           @unique
  nomBoutique    String
  description    String?       @db.Text
  photoCouverture String?
  localite       String
  specialite     String
  mobileMoneyNum  String?
  pieceIdentite   String?
  photosOeuvres   Json?
  statut          StatutArtisan @default(EN_ATTENTE)
  createdAt       DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  produits  Produit[]
  commandes Commande[]

  @@map("artisans")
}

model Categorie {
  id       Int       @id @default(autoincrement())
  nom      String    @unique
  slug     String    @unique
  icone    String?
  produits Produit[]

  @@map("categories")
}

model Produit {
  id              Int           @id @default(autoincrement())
  artisanId       Int
  categorieId     Int
  titre           String
  description     String        @db.Text
  prix            Decimal       @db.Decimal(10, 2)
  quantite        Int           @default(0)
  seuilAlerte     Int           @default(5)
  photos          Json
  delaiLivraison  String?
  personnalisable Boolean       @default(false)
  statut          StatutProduit @default(BROUILLON)
  vues            Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  artisan   Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  categorie Categorie @relation(fields: [categorieId], references: [id])
  avis      Avis[]
  favoris   Favori[]
  articles  ArticleCommande[]

  @@map("produits")
}

model Adresse {
  id         Int    @id @default(autoincrement())
  userId     Int
  libelle    String
  ville      String
  quartier   String
  details    String?
  principale Boolean @default(false)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  commandes Commande[]

  @@map("adresses")
}

model Commande {
  id          Int            @id @default(autoincrement())
  clientId    Int
  adresseId   Int?
  statut      StatutCommande @default(RECUE)
  total       Decimal        @db.Decimal(10, 2)
  surMesure     Boolean        @default(false)
  detailsMesure Json?
  devisPrix     Decimal?       @db.Decimal(10, 2)
  devisMessage  String?        @db.Text
  devisStatut   String         @default("EN_ATTENTE")
  artisanId     Int?
  paiementId    String?
  paiementStatut String        @default("en_attente")
  commission    Decimal?       @db.Decimal(10, 2)
  receptionConfirmee Boolean   @default(false)
  fondsLiberes       Boolean   @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  client   User              @relation("CommandeClient", fields: [clientId], references: [id])
  adresse  Adresse?          @relation(fields: [adresseId], references: [id])
  artisan  Artisan?          @relation(fields: [artisanId], references: [id])
  articles ArticleCommande[]

  @@map("commandes")
}

model ArticleCommande {
  id           Int     @id @default(autoincrement())
  commandeId   Int
  produitId    Int
  quantite     Int
  prixUnitaire Decimal @db.Decimal(10, 2)

  commande Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit  Produit  @relation(fields: [produitId], references: [id])

  @@map("articles_commande")
}

model Avis {
  id          Int      @id @default(autoincrement())
  clientId    Int
  produitId   Int
  note        Int
  commentaire String?  @db.Text
  photo       String?
  createdAt   DateTime @default(now())

  client  User    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  produit Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)

  @@unique([clientId, produitId])
  @@map("avis")
}

model Favori {
  clientId  Int
  produitId Int
  createdAt DateTime @default(now())

  client  User    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  produit Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)

  @@id([clientId, produitId])
  @@map("favoris")
}

model Message {
  id          Int      @id @default(autoincrement())
  expediteurId Int
  destinataireId Int
  commandeId  Int?
  contenu     String   @db.Text
  fichier     String?
  lu          Boolean  @default(false)
  createdAt   DateTime @default(now())

  expediteur User @relation(fields: [expediteurId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Litige {
  id          Int      @id @default(autoincrement())
  commandeId  Int
  clientId    Int
  artisanId   Int
  motif       String
  description String   @db.Text
  preuvePhoto String?
  statut      String   @default("OUVERT")   // OUVERT | EN_COURS | RESOLU | REJETE
  reponseArtisan String? @db.Text
  resolution  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("litiges")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  titre     String
  message   String
  lu        Boolean  @default(false)
  lien      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model MessageContact {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String
  sujet     String?
  message   String
  lu        Boolean  @default(false)
  repondu   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("messages_contact")
}
